{
  "rewrites": [
    { "source": "/library", "destination": "/library.html" },
    { "source": "/library/**", "destination": "/library/book.html" }
  ],
  "headers": [
    {
      "source": "**",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate" }
      ]
    }
  ]
}
